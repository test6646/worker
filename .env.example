# ─── Required ────────────────────────────────────────────────────────────────
# Supabase — service role so the worker can read fyers_session and upsert
# last_quotes without RLS.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Fyers app credentials.
FYERS_APP_ID=XXXXXXX-100

# Shared with fyers-ws-ticket edge function. Worker verifies the ticket
# the browser presents on the WS handshake using this exact secret.
FYERS_TICKET_SECRET=<same value as Supabase secret FYERS_TICKET_SECRET>

# Direct Postgres URL for the sync pipeline.
DATABASE_URL=postgres://...

# Bearer token that /sync/* endpoints require.
SYNC_SHARED_SECRET=<random long secret>

# ─── Optional ────────────────────────────────────────────────────────────────
PORT=3000

# Comma-separated origins allowed to open the WS. Leave empty to allow any.
ALLOWED_ORIGINS=

# IPO source (only needed if you run /sync/ipo).
IPONOTIFY_API_KEY=

# ─── Tuning (defaults shown) ─────────────────────────────────────────────────
# Market hours (IST minutes-of-day) — override for other exchanges.
MARKET_TZ=Asia/Kolkata
MARKET_OPEN_MIN=555       # 09:15
MARKET_CLOSE_MIN=932      # 15:32 (2-min post-close grace for closing-auction ticks)

# Timers (ms).
SESSION_POLL_MS=60000
WATCHED_REFRESH_MS=30000
LAST_QUOTE_TTL_MS=5000
SETTLE_THROTTLE_MS=400
MARKET_STATUS_BROADCAST_MS=30000

# Upstream reconnect state machine.
UPSTREAM_CONNECT_TIMEOUT_MS=15000
UPSTREAM_RECONNECT_BASE_MS=1000
UPSTREAM_RECONNECT_MAX_MS=30000
UPSTREAM_LIVENESS_MS=90000
UPSTREAM_LIVENESS_CHECK_MS=15000
UPSTREAM_CIRCUIT_FAILURES=6
UPSTREAM_CIRCUIT_COOLDOWN_MS=120000

# Per-symbol live-feed repair during market hours only.
SUBSCRIBE_CHUNK_SIZE=40
SUBSCRIBE_CHUNK_GAP_MS=30
SYMBOL_LIVENESS_MS=60000
SYMBOL_LIVENESS_CHECK_MS=20000
SYMBOL_RESUB_BATCH=10

# Sync pipeline tuning.
SYNC_BATCH_SIZE=2000
SYNC_HTTP_UA=Mozilla/5.0 (compatible; sync-worker/1.0)
FYERS_SYMBOL_SOURCES_URL=https://public.fyers.in/sym_details
IPONOTIFY_BASE=https://iponotify.me/api/ipo
AMFI_URL=https://www.amfiindia.com/spages/NAVAll.txt

# Postgres session timeouts for the sync pipeline (ms). Supabase's pooler
# role has a low default statement_timeout (~8s) — sync_finalize and large
# batch upserts legitimately need minutes. Point DATABASE_URL at the
# Supabase session pooler (port 5432) or a direct connection so these
# session options are honoured end-to-end.
SYNC_STATEMENT_TIMEOUT_MS=600000
SYNC_FINALIZE_TIMEOUT_MS=600000
